# Preventli Environment Variables
# Copy this file to .env and fill in your values
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# =============================================================================
# REQUIRED — Application will not start without these
# =============================================================================

# PostgreSQL Database Connection
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/gpnet3

# JWT Secret (min 32 chars, generate with crypto.randomBytes(32).toString('hex'))
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Session/CSRF Secret (min 32 chars, different from JWT_SECRET)
SESSION_SECRET=your-session-secret-min-32-chars

# =============================================================================
# LLM PROVIDER — Required for AI features
# =============================================================================

# Provider: 'groq' (recommended — Apache 2.0, ~14x cheaper) | 'openrouter' | 'anthropic'
LLM_PROVIDER=groq

# Groq API key (used when LLM_PROVIDER=groq)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxx

# OpenRouter API key (used when LLM_PROVIDER=openrouter)
# Get from: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-xxxxx

# Anthropic API key (used when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# Override LLM model (optional — defaults per provider: groq→qwen/qwen3-32b, openrouter→claude-sonnet-4-5)
# LLM_MODEL=qwen/qwen3-32b

# =============================================================================
# FILE STORAGE — Required for file uploads (logos, job descriptions)
# =============================================================================

# Storage provider: 'local' (development) or 's3' (production)
# Defaults to 'local' in development, 's3' in production
STORAGE_PROVIDER=local

# AWS S3 / Cloudflare R2 configuration (required when STORAGE_PROVIDER=s3)
# AWS_S3_BUCKET=preventli-uploads
# AWS_S3_REGION=ap-southeast-2
# AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AWS_S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com  # For Cloudflare R2
# AWS_S3_PUBLIC_URL=https://cdn.preventli.ai               # CDN URL (optional)

# =============================================================================
# FRESHDESK INTEGRATION
# =============================================================================

# Your Freshdesk subdomain (e.g., "mycompany" from mycompany.freshdesk.com)
FRESHDESK_DOMAIN=your-subdomain
# Freshdesk API Key from Profile Settings > API Key
FRESHDESK_API_KEY=your-freshdesk-api-key

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

PORT=5000
NODE_ENV=development

# Frontend URL (for CORS and invite links)
CLIENT_URL=http://localhost:5173

# Application URL (for notification links in emails)
APP_URL=http://localhost:5173

# API URL (for webhook URLs in external services)
API_URL=http://localhost:5000

# =============================================================================
# DATABASE POOL TUNING (optional — safe defaults provided)
# =============================================================================

# DB_POOL_MAX=20
# DB_POOL_IDLE_TIMEOUT=30000
# DB_POOL_CONNECT_TIMEOUT=5000
# DATABASE_SSL=false  # Set to true for managed databases (RDS, Neon, Supabase)
# DATABASE_SSL_REJECT_UNAUTHORIZED=true

# =============================================================================
# EMAIL / SMTP
# =============================================================================
# Recommended provider: Resend (resend.com) — free tier, great deliverability
#   1. Sign up at resend.com
#   2. Add + verify your domain (preventli.ai)
#   3. Create an API key
#   4. Set these vars:
#      SMTP_HOST=smtp.resend.com
#      SMTP_PORT=587
#      SMTP_USER=resend
#      SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxx   (your Resend API key)
#      SMTP_SECURE=false
#      SMTP_FROM=noreply@preventli.ai
#
# Verify setup: POST /api/notifications/test (admin-only, sends to your login email)

# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_your_api_key_here
# SMTP_SECURE=false
# SMTP_FROM=noreply@preventli.ai

# Who receives new telehealth booking notifications (defaults to jacinta@preventli.ai)
# BOOKING_NOTIFY_EMAIL=jacinta@preventli.ai

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable background notification scheduler (true/false)
ENABLE_NOTIFICATIONS=false

# Enable daily Freshdesk sync
DAILY_SYNC_ENABLED=false
DAILY_SYNC_TIME=18:00

# Enable compliance check scheduler
COMPLIANCE_CHECK_ENABLED=false
COMPLIANCE_CHECK_TIME=06:00

# Enable AI agent scheduler
AGENTS_ENABLED=false
AGENT_COORDINATOR_TIME=09:00
AGENT_CERT_EXPIRY_TIME=08:00

# =============================================================================
# MONITORING
# =============================================================================

# Sentry DSN for error tracking (optional but strongly recommended in production)
# Get from: https://sentry.io → New Project → Node.js
# SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# CLIENT-SIDE (Vite) — Embedded into the browser bundle at build time
# =============================================================================

# Client Sentry DSN — get from sentry.io → Project → Client Keys
# VITE_SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0

# Client API base URL — must match the running backend
VITE_API_URL=http://localhost:5000

# Log level: debug | info | warn | error
LOG_LEVEL=debug

# =============================================================================
# ALERTING — Operational alerts for system failures
# =============================================================================

# Slack incoming webhook URL — receives alerts for AI/DB/storage failures
# Get from: https://api.slack.com/messaging/webhooks
# ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/T.../B.../xxx

# Telegram webhook URL — receives alerts via Telegram Bot API
# Format: https://api.telegram.org/bot<TOKEN>/sendMessage?chat_id=<CHAT_ID>
# ALERT_TELEGRAM_WEBHOOK=https://api.telegram.org/bot123:ABC.../sendMessage?chat_id=-100123

# Telegram webhook for inbound-email draft pings (email-drafter v0).
# Kept SEPARATE from ALERT_TELEGRAM_WEBHOOK so draft notifications don't
# pollute the on-call alert channel. If unset, drafts are still created
# and persisted — only the Telegram ping is skipped.
# DRAFT_TELEGRAM_WEBHOOK=https://api.telegram.org/bot123:ABC.../sendMessage?chat_id=<chat_id>

# =============================================================================
# WEBHOOKS
# =============================================================================

# Secret for inbound email webhook (use a strong random string)
# INBOUND_EMAIL_WEBHOOK_SECRET=your-webhook-secret-here

# Discord webhook for notifications (optional)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# =============================================================================
# TESTING
# =============================================================================

# Base URL for Playwright E2E tests
PLAYWRIGHT_BASE_URL=http://localhost:5000
